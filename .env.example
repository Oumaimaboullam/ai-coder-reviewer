# -----------------------------------------------------
# Général
# -----------------------------------------------------
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# -----------------------------------------------------
# MongoDB
# -----------------------------------------------------
# Utilisé par Docker Compose pour le setup initial
MONGO_ROOT_USER=root
MONGO_ROOT_PASS=password

# -----------------------------------------------------
# RabbitMQ
# -----------------------------------------------------
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672
RABBITMQ_USER=guest
RABBITMQ_PASS=guest

# -----------------------------------------------------
# JWT Secrets (générer des clés fortes en production)
# -----------------------------------------------------
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here

# -----------------------------------------------------
# OpenRouter API (Service AI)
# Obtenir une clé: https://openrouter.ai/
# -----------------------------------------------------
OPENROUTER_API_KEY=your_openrouter_api_key_here
AI_MODEL=mistralai/mistral-7b-instruct-v0.1
AI_FALLBACK_MODEL=openchat/openchat-7b
AI_MAX_TOKENS=2000
AI_TEMPERATURE=0.3

# -----------------------------------------------------
# Stripe API (Service Paiement)
# Obtenir des clés: https://dashboard.stripe.com/apikeys
# -----------------------------------------------------
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here

# -----------------------------------------------------
# Services URLs (pour Docker Compose interne)
# -----------------------------------------------------
AUTH_SERVICE_URL=http://auth-service:3001
CODE_SERVICE_URL=http://code-service:3002
AI_SERVICE_URL=http://ai-service:3003
PAYMENT_SERVICE_URL=http://payment-service:3004

# AI Service Environment Variables
PORT=3003
NODE_ENV=development

# AI Configuration (OpenRouter)
# Obtenir une clé: https://openrouter.ai/
OPENROUTER_API_KEY=your_openrouter_api_key_here
AI_MODEL=mistralai/mistral-7b-instruct-v0.1
AI_FALLBACK_MODEL=openchat/openchat-7b
AI_MAX_TOKENS=2000
AI_TEMPERATURE=0.3
AI_SITE_URL=http://localhost:3000
AI_SITE_NAME=AI Code Reviewer

# RabbitMQ Configuration
RABBITMQ_URL=amqp://localhost:5672
RABBITMQ_QUEUE=ai-service-queue
